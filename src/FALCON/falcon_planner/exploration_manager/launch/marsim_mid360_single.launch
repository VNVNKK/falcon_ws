<launch>
  <arg name="map_pcd" default="$(find map_generator)/resource/small_forest01cutoff.pcd"/>
  <arg name="downsample_resolution" default="0.1"/>
  <arg name="use_gpu" default="false"/>

  <arg name="drone_id" default="0"/>
  <arg name="drone_num" default="1"/>
  <arg name="init_x" default="0.0"/>
  <arg name="init_y" default="0.0"/>
  <arg name="init_z" default="1.0"/>
  <arg name="init_yaw" default="0.0"/>
  <arg name="odom_topic" default="lidar_slam/odom"/>
  <arg name="use_uav_extra_model" default="0"/>

  <node pkg="map_generator" name="map_pub" type="map_pub" output="log" args="$(arg map_pcd)">
    <param name="add_boundary" value="0"/>
    <param name="is_bridge" value="0"/>
    <param name="downsample_res" value="$(arg downsample_resolution)"/>
    <param name="map_offset_x" value="0.0"/>
    <param name="map_offset_y" value="0.0"/>
    <param name="map_offset_z" value="0.0"/>
  </node>

  <node pkg="mars_drone_sim" name="quad$(arg drone_id)_quadrotor_dynamics"
        type="quadrotor_dynamics_node" output="log">
    <remap from="~odom" to="/quad_$(arg drone_id)/$(arg odom_topic)"/>
    <remap from="~cmd_RPM" to="/quad_$(arg drone_id)/cmdRPM"/>
    <remap from="~imu" to="/quad_$(arg drone_id)/imu"/>
    <param name="mass" value="1.9"/>
    <param name="simulation_rate" value="200"/>
    <param name="quadrotor_name" value="quad_$(arg drone_id)"/>
    <param name="init_state_x" value="$(arg init_x)"/>
    <param name="init_state_y" value="$(arg init_y)"/>
    <param name="init_state_z" value="$(arg init_z)"/>
  </node>

  <node pkg="cascadePID" name="quad$(arg drone_id)_cascadePID_node" type="cascadePID_node"
        output="log">
    <param name="drone_id" value="$(arg drone_id)"/>
    <remap from="~odom" to="/quad_$(arg drone_id)/$(arg odom_topic)"/>
    <remap from="~cmd_RPM" to="/quad_$(arg drone_id)/cmdRPM"/>
    <remap from="~cmd_pose" to="/goal"/>
    <remap from="~position_cmd" to="/quad_$(arg drone_id)/planning/pos_cmd"/>
    <param name="controller_rate" value="200"/>
    <param name="quadrotor_name" value="quad_$(arg drone_id)"/>
    <param name="init_state_x" value="$(arg init_x)"/>
    <param name="init_state_y" value="$(arg init_y)"/>
    <param name="init_state_z" value="$(arg init_z)"/>
    <param name="init_state_yaw" value="$(arg init_yaw)"/>
    <param name="angle_stable_time" value="0.5"/>
    <param name="damping_ratio" value="1.0"/>
  </node>

  <node pkg="odom_visualization" name="quad$(arg drone_id)_odom_visualization"
        type="odom_visualization" output="log">
    <remap from="~odometry" to="/quad_$(arg drone_id)/$(arg odom_topic)"/>
    <param name="color/a" value="1.0"/>
    <param name="color/r" value="0.0"/>
    <param name="color/g" value="1.0"/>
    <param name="color/b" value="1.0"/>
    <param name="covariance_scale" value="100.0"/>
    <param name="robot_scale" value="1.0"/>
    <param name="mesh_resource" value="package://odom_visualization/meshes/hummingbird.mesh"/>
  </node>

  <group if="$(arg use_gpu)">
    <node pkg="local_sensing_node" type="opengl_render_node"
          name="quad$(arg drone_id)_pcl_render_node" output="log" args="$(arg map_pcd)">
      <remap from="~global_map" to="/map_generator/global_cloud"/>
      <remap from="~odometry" to="/quad_$(arg drone_id)/$(arg odom_topic)"/>

      <param name="drone_id" value="$(arg drone_id)"/>
      <param name="quadrotor_name" value="quad_$(arg drone_id)"/>
      <param name="uav_num" value="$(arg drone_num)"/>
      <param name="is_360lidar" value="1"/>
      <param name="sensing_horizon" value="20.0"/>
      <param name="sensing_rate" value="5.0"/>
      <param name="estimation_rate" value="10.0"/>
      <param name="polar_resolution" value="0.4"/>
      <param name="yaw_fov" value="360.0"/>
      <param name="vertical_fov" value="90.0"/>
      <param name="min_raylength" value="1.0"/>
      <param name="livox_linestep" value="1.4"/>
      <param name="curvature_limit" value="100.0"/>
      <param name="hash_cubesize" value="5.0"/>
      <param name="use_avia_pattern" value="0"/>
      <param name="use_vlp32_pattern" value="0"/>
      <param name="use_minicf_pattern" value="1"/>
      <param name="use_os128_pattern" value="0"/>
      <param name="use_gaussian_filter" value="0"/>
      <param name="downsample_res" value="$(arg downsample_resolution)"/>
      <param name="dynobj_enable" value="0"/>
      <param name="dynobject_size" value="0.8"/>
      <param name="dynobject_num" value="10"/>
      <param name="dyn_mode" value="0"/>
      <param name="dyn_velocity" value="1.0"/>
      <param name="use_uav_extra_model" value="$(arg use_uav_extra_model)"/>
      <param name="collisioncheck_enable" value="0"/>
      <param name="collision_range" value="0.3"/>
      <param name="output_pcd" value="0"/>
    </node>
  </group>

  <group unless="$(arg use_gpu)">
    <node pkg="local_sensing_node" type="pcl_render_node"
          name="quad$(arg drone_id)_pcl_render_node" output="log">
      <remap from="~global_map" to="/map_generator/global_cloud"/>
      <remap from="~odometry" to="/quad_$(arg drone_id)/$(arg odom_topic)"/>

      <param name="drone_id" value="$(arg drone_id)"/>
      <param name="quadrotor_name" value="quad_$(arg drone_id)"/>
      <param name="uav_num" value="$(arg drone_num)"/>
      <param name="is_360lidar" value="1"/>
      <param name="sensing_horizon" value="15.0"/>
      <param name="sensing_rate" value="10.0"/>
      <param name="estimation_rate" value="10.0"/>
      <param name="polar_resolution" value="0.2"/>
      <param name="yaw_fov" value="360.0"/>
      <param name="vertical_fov" value="90.0"/>
      <param name="min_raylength" value="1.0"/>
      <param name="livox_linestep" value="1.4"/>
      <param name="curvature_limit" value="100.0"/>
      <param name="hash_cubesize" value="5.0"/>
      <param name="use_avia_pattern" value="0"/>
      <param name="use_vlp32_pattern" value="0"/>
      <param name="use_minicf_pattern" value="1"/>
      <param name="downsample_res" value="$(arg downsample_resolution)"/>
      <param name="dynobj_enable" value="0"/>
      <param name="dynobject_size" value="0.6"/>
      <param name="dynobject_num" value="30"/>
      <param name="dyn_mode" value="2"/>
      <param name="dyn_velocity" value="3.0"/>
      <param name="use_uav_extra_model" value="$(arg use_uav_extra_model)"/>
      <param name="collisioncheck_enable" value="0"/>
      <param name="collision_range" value="0.3"/>
      <param name="output_pcd" value="0"/>
    </node>
  </group>
</launch>
